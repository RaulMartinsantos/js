{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2023", "DOM"],

    "module": "node16",
    "moduleResolution": "node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
